# OpenTofu state and plan artifacts — NEVER commit
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# OpenTofu working directory and provider cache
.terraform/
.terraform.tfstate.lock.info

# OpenTofu variable files — often contain secrets
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# OpenTofu override files — often used for local-only config
override.tf
override.tf.json
*_override.tf
*_override.tf.json
override.tofu
override.tofu.json
*_override.tofu
*_override.tofu.json

# Credentials and environment files
.env
.env.*
.envrc
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*

# Editor/tool local state
.worktrees/
.idea/
.vscode/
*.swp
.DS_Store
